# Test your FastAPI endpoints

GET http://127.0.0.1:8000/
Accept: application/json

###

### Create a new device (Location) with tag and coordinates
POST http://127.0.0.1:8000/api/v1/locations/
Content-Type: application/json

{
  "id": "device_002",
  "name": "Microphone 2",
  "tag": "Ратуша ул Павла 4",
  "lat": 55.7558,
  "lon": 37.6173
}

### Get all devices
GET http://127.0.0.1:8000/api/v1/locations/
Accept: application/json

### Update device settings
PUT http://127.0.0.1:8000/api/v1/locations/device_002
Content-Type: application/json

{
  "name": "Updated Mic 2",
  "tag": "New Tag",
  "lat": 55.7559
}

### Get peaks for a specific device
GET http://127.0.0.1:8000/api/v1/peaks/device/device_001
Accept: application/json

### Get all triangulated points
GET http://127.0.0.1:8000/api/v1/triangulated_points/
Accept: application/json

### Register Device 1
POST http://127.0.0.1:8000/api/v1/locations/
Content-Type: application/json

{
  "id": "dev001",
  "name": "Mic 1",
  "lat": 55.751244,
  "lon": 37.618423
}

### Register Device 2
POST http://127.0.0.1:8000/api/v1/locations/
Content-Type: application/json

{
  "id": "dev002",
  "name": "Mic 2",
  "lat": 55.755814,
  "lon": 37.617635
}

### Register Device 3
POST http://127.0.0.1:8000/api/v1/locations/
Content-Type: application/json

{
  "id": "dev003",
  "name": "Mic 3",
  "lat": 55.75222,
  "lon": 37.6237
}

### Send Peak 1 (from Device 1)
POST http://127.0.0.1:8000/api/v1/peaks/
Content-Type: application/json
X-Device-ID: dev001

{
  "peak_time": "2026-04-12T10:00:00.000Z"
}

### Send Peak 2 (from Device 2)
POST http://127.0.0.1:8000/api/v1/peaks/
Content-Type: application/json
X-Device-ID: dev002

{
  "peak_time": "2026-04-12T10:00:00.100Z"
}

### Send Peak 3 (from Device 3)
POST http://127.0.0.1:8000/api/v1/peaks/
Content-Type: application/json
X-Device-ID: dev003

{
  "peak_time": "2026-04-12T10:00:00.050Z"
}

### Get triangulated points after peaks
GET http://127.0.0.1:8000/api/v1/triangulated_points/
Accept: application/json

### Initialize device and sync time
POST http://127.0.0.1:8000/api/v1/locations/dev001/init
Accept: application/json

### Delete a device
DELETE http://127.0.0.1:8000/api/v1/locations/device_002
Accept: application/json

###
